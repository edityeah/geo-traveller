# --- Required at build time ---

# Notion integration token (from notion.so/my-integrations)
NOTION_TOKEN=secret_...

# Notion database ID for the Posts database
# Get from the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=

# Optional: limit how many posts to fetch (useful while developing)
# NOTION_FETCH_LIMIT=10


# --- Optional integrations (any can be left blank) ---

# Cloudflare Web Analytics token (from Cloudflare dashboard -> Web Analytics)
# When set, the beacon script is injected on every page.
PUBLIC_CFA_TOKEN=

# Microsoft Clarity project ID (from clarity.microsoft.com)
# When set, the Clarity session-recording + heatmap snippet loads.
PUBLIC_CLARITY_ID=

# Buttondown newsletter username (from buttondown.com)
# When set, a subscribe form appears in the site footer.
PUBLIC_BUTTONDOWN_USER=

# Giscus comments configuration (from giscus.app)
# All four must be set for comments to render. Leave blank to hide them.
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=
