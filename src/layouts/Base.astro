---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  publishedTime?: Date;
}

const { title, description, ogImage, publishedTime } = Astro.props;
const siteTitle = 'Geo-Traveller';
const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription =
  description ?? 'A travel journal: places, people, and the long way around.';
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={publishedTime ? 'article' : 'website'} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">Geo-Traveller</a>
      <nav>
        <a href="/archive/">Archive</a>
        <a href="/about/">About</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      &copy; {new Date().getFullYear()} Geo-Traveller. Built with Astro + Notion.
    </footer>
  </body>
</html>
