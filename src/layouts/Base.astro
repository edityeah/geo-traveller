---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  publishedTime?: Date;
}

const { title, description, ogImage, publishedTime } = Astro.props;
const siteTitle = 'Geo-Traveller';
const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription =
  description ?? 'A travel journal: places, people, and the long way around.';
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const cfaToken = import.meta.env.PUBLIC_CFA_TOKEN;
const buttondownUser = import.meta.env.PUBLIC_BUTTONDOWN_USER;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={publishedTime ? 'article' : 'website'} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">Geo-Traveller</a>
      <nav>
        <a href="/archive/">Archive</a>
        <a href="/map/">Map</a>
        <a href="/gallery/">Gallery</a>
        <a href="/search/">Search</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      {buttondownUser && (
        <form
          action={`https://buttondown.email/api/emails/embed-subscribe/${buttondownUser}`}
          method="post"
          target="_blank"
          class="newsletter"
        >
          <label for="bd-email">Get new posts by email</label>
          <input id="bd-email" type="email" name="email" placeholder="you@example.com" required />
          <button type="submit">Subscribe</button>
        </form>
      )}
      <p>
        &copy; {new Date().getFullYear()} Geo-Traveller · <a href="/rss.xml">RSS</a> · Built with Astro + Notion
      </p>
    </footer>
    {cfaToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfaToken}"}`}
      ></script>
    )}
  </body>
</html>
