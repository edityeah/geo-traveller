---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import { SITE, websiteLd } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  ogType?: 'website' | 'article';
  articleTags?: string[];
  articleAuthor?: string;
  /** Pre-built JSON-LD object(s) for this specific page. Site-level WebSite is always emitted. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Hint to search engines. Default is index,follow. */
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  publishedTime,
  modifiedTime,
  ogType,
  articleTags,
  articleAuthor,
  jsonLd,
  noindex,
} = Astro.props;
const pageTitle = title ? `${title} — ${SITE.name}` : SITE.name;
const siteDescription = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedOgType = ogType ?? (publishedTime ? 'article' : 'website');
const ogImageAbs = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).toString())
  : new URL(SITE.logo, Astro.site).toString();

const cfaToken = import.meta.env.PUBLIC_CFA_TOKEN;
const googleVerify = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingVerify = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const clarityId = import.meta.env.PUBLIC_CLARITY_ID;

// Pages flagged with `showInFooter` in Notion appear in the footer nav.
const allPages = await getCollection('pages');
const footerPages = allPages
  .filter((p) => p.data.showInFooter)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Collect all JSON-LD objects to emit.
const lds: Record<string, unknown>[] = [websiteLd()];
if (jsonLd) {
  if (Array.isArray(jsonLd)) lds.push(...jsonLd);
  else lds.push(jsonLd);
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="author" content={articleAuthor ?? SITE.author.name} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    {googleVerify && <meta name="google-site-verification" content={googleVerify} />}
    {bingVerify && <meta name="msvalidate.01" content={bingVerify} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/img/brand/logo-square.png" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content={title ?? SITE.name} />
    {publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}
    {articleTags?.map((t) => <meta property="article:tag" content={t} />)}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.author.twitterHandle} />
    <meta name="twitter:creator" content={SITE.author.twitterHandle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- JSON-LD structured data -->
    {lds.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label={`${SITE.name} — home`}>
        <img src="/img/brand/logo.png" alt={SITE.name} />
      </a>
      <SiteNav />
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/"><img src="/img/brand/logo.png" alt={SITE.name} /></a>
          <p class="footer-tag">A travel journal. India and beyond.</p>
        </div>
        <nav class="footer-nav">
          <a href="/">Home</a>
          <a href="/map/">Map</a>
          <a href="/gallery/">Gallery</a>
          {footerPages.map((p) => (
            <a href={`/${p.data.slug}/`}>{p.data.title}</a>
          ))}
        </nav>
        <div class="footer-social">
          <a href="https://www.instagram.com/thegeotraveller/" rel="me noopener" target="_blank" aria-label="Instagram">Instagram</a>
          <a href="https://www.linkedin.com/in/adityacbcc/" rel="me noopener" target="_blank" aria-label="LinkedIn">LinkedIn</a>
          <a href="http://facebook.com/thegeotraveller" rel="me noopener" target="_blank" aria-label="Facebook">Facebook</a>
        </div>
        <p class="footer-copy">
          &copy; {new Date().getFullYear()} {SITE.name} · India · All rights reserved
        </p>
      </div>
    </footer>
    {cfaToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfaToken}"}`}
      ></script>
    )}
    {clarityId && (
      <script is:inline set:html={`
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", ${JSON.stringify(clarityId)});
      `}></script>
    )}
  </body>
</html>
