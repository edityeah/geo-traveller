---
import type { Post } from '../lib/posts';
import { postPath, readMinutes, formatDate } from '../lib/posts';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const href = postPath(post);
const date = formatDate(post.data.publishDate);
const mins = readMinutes(post);
---

<article class="card">
  <a href={href}>
    {post.data.cover ? (
      <div class="cover"><img src={post.data.cover} alt={post.data.title} loading="lazy" /></div>
    ) : (
      <div class="cover placeholder" aria-hidden="true"></div>
    )}
    <div class="meta">
      <span>{date}</span>
      {post.data.locationName && (
        <>
          <span class="dot"></span>
          <span>{post.data.locationName}</span>
        </>
      )}
      <span class="dot"></span>
      <span>{mins} min</span>
    </div>
    <h2>{post.data.title}</h2>
    {post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
  </a>
</article>
