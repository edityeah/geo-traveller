---
interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;

const enc = (s: string) => encodeURIComponent(s);

const targets = [
  { name: 'X', href: `https://twitter.com/intent/tweet?url=${enc(url)}&text=${enc(title)}`, label: 'Share on X' },
  { name: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}`, label: 'Share on Facebook' },
  { name: 'WhatsApp', href: `https://api.whatsapp.com/send?text=${enc(title + ' — ' + url)}`, label: 'Share on WhatsApp' },
  { name: 'LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`, label: 'Share on LinkedIn' },
];
---

<div class="share-bar" aria-label="Share this post">
  <span class="share-label">Share</span>
  <div class="share-icons">
    {targets.map((t) => (
      <a href={t.href} target="_blank" rel="noopener" aria-label={t.label} title={t.label} data-share={t.name}>
        {t.name === 'X' && (
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M18.244 2H21.5l-7.61 8.69L23 22h-7.094l-5.55-7.265L4 22H.744l8.137-9.296L1 2h7.273l5.022 6.638L18.244 2zm-1.246 18h1.834L7.116 4H5.15l11.847 16z"/></svg>
        )}
        {t.name === 'Facebook' && (
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M24 12.07C24 5.41 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.7 4.54-4.7 1.31 0 2.69.24 2.69.24v2.97h-1.51c-1.5 0-1.96.93-1.96 1.89v2.27h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
        )}
        {t.name === 'WhatsApp' && (
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M20.52 3.48A11.85 11.85 0 0012.04 0C5.46 0 .12 5.34.12 11.92c0 2.1.55 4.15 1.6 5.95L0 24l6.27-1.64a11.9 11.9 0 005.77 1.47h.01c6.58 0 11.92-5.34 11.92-11.92 0-3.18-1.24-6.17-3.45-8.43zM12.05 21.79h-.01a9.86 9.86 0 01-5.04-1.38l-.36-.21-3.72.98 1-3.63-.24-.37a9.85 9.85 0 01-1.51-5.26c0-5.47 4.45-9.92 9.92-9.92 2.65 0 5.14 1.03 7.01 2.91a9.86 9.86 0 012.9 7.02c0 5.47-4.45 9.86-9.95 9.86zm5.45-7.4c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.78.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51l-.57-.01a1.1 1.1 0 00-.8.37c-.27.3-1.05 1.03-1.05 2.5s1.07 2.9 1.22 3.1c.15.2 2.11 3.22 5.12 4.52.71.31 1.27.49 1.71.63.72.23 1.37.2 1.89.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.18-1.42-.07-.13-.27-.2-.57-.35z"/></svg>
        )}
        {t.name === 'LinkedIn' && (
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M19 0H5a5 5 0 00-5 5v14a5 5 0 005 5h14a5 5 0 005-5V5a5 5 0 00-5-5zM8 19H5V8h3v11zM6.5 6.73a1.77 1.77 0 110-3.54 1.77 1.77 0 010 3.54zM20 19h-3v-5.6c0-3.37-4-3.11-4 0V19h-3V8h3v1.77c1.4-2.59 7-2.78 7 2.48V19z"/></svg>
        )}
      </a>
    ))}
    <button type="button" class="copy-btn" aria-label="Copy link" data-url={url} title="Copy link">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
      <span class="copy-feedback" aria-live="polite"></span>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url || window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        const fb = btn.querySelector('.copy-feedback');
        if (fb) {
          fb.textContent = 'Copied!';
          setTimeout(() => { (fb as HTMLElement).textContent = ''; }, 1500);
        }
      } catch (err) {
        console.error('copy failed', err);
      }
    });
  });
</script>

<style>
  .share-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem auto;
    max-width: var(--measure);
    padding: 0.75rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .share-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-weight: 600;
  }
  .share-icons {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .share-icons a,
  .share-icons .copy-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--rule);
    cursor: pointer;
    transition: all 0.15s ease;
    position: relative;
  }
  .share-icons a:hover,
  .share-icons .copy-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--bg-warm);
  }
  .copy-feedback {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--fg);
    color: var(--bg);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    white-space: nowrap;
    pointer-events: none;
  }
  .copy-feedback:empty { display: none; }
</style>
