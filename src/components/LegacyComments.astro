---
import comments from '../data/wp-comments.json';

interface Props {
  originalUrl?: string;
}
const { originalUrl } = Astro.props;

type LegacyComment = {
  id: string;
  author: string;
  authorUrl?: string;
  date: string;
  content: string;
  parentId?: string;
};

// The migration captured the post's original WP URL. Strip trailing slashes
// and protocol normalization just in case.
function lookup(url?: string): LegacyComment[] {
  if (!url) return [];
  const all = comments as Record<string, LegacyComment[]>;
  if (all[url]) return all[url];
  const noSlash = url.replace(/\/$/, '');
  if (all[noSlash]) return all[noSlash];
  const httpsToHttp = url.replace('https://', 'http://');
  if (all[httpsToHttp]) return all[httpsToHttp];
  return [];
}

const list = lookup(originalUrl);

function formatDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso.replace(' ', 'T') + 'Z');
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function safeHref(url?: string): string | null {
  if (!url) return null;
  try {
    const u = new URL(url);
    if (u.protocol !== 'http:' && u.protocol !== 'https:') return null;
    return u.toString();
  } catch {
    return null;
  }
}
---

{list.length > 0 && (
  <section class="legacy-comments">
    <header>
      <h2>Earlier conversations</h2>
      <p>From the WordPress era — preserved as written.</p>
    </header>
    <ol>
      {list.map((c) => {
        const url = safeHref(c.authorUrl);
        return (
          <li>
            <div class="meta">
              {url ? (
                <a href={url} rel="nofollow noopener" target="_blank">{c.author}</a>
              ) : (
                <span class="author">{c.author}</span>
              )}
              <span class="dot">·</span>
              <span class="date">{formatDate(c.date)}</span>
            </div>
            <p class="body">{c.content}</p>
          </li>
        );
      })}
    </ol>
  </section>
)}

<style>
  .legacy-comments {
    max-width: var(--measure);
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }
  .legacy-comments header h2 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }
  .legacy-comments header p {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0 0 1.5rem;
    font-style: italic;
  }
  .legacy-comments ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }
  .legacy-comments li {
    padding: 1rem 1.25rem;
    background: var(--bg-warm);
    border-radius: 4px;
    border-left: 3px solid var(--rule-strong);
  }
  .legacy-comments .meta {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .legacy-comments .meta a,
  .legacy-comments .meta .author {
    color: var(--fg);
    font-weight: 600;
    text-decoration: none;
  }
  .legacy-comments .meta a:hover { color: var(--accent); }
  .legacy-comments .body {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--fg-soft);
    white-space: pre-wrap;
  }
</style>
