---
import Base from '../layouts/Base.astro';
---

<Base title="About">
  <article style="max-width: var(--measure); margin: 0 auto;">
    <h1 class="page-title">About</h1>
    <p>
      Geo-Traveller is a personal travel journal. Notes, photos, and stories
      from places I've been lucky enough to wander through.
    </p>
    <p>
      Built with Astro and Notion. Hosted on Cloudflare Pages. Source on
      GitHub.
    </p>
  </article>
</Base>
