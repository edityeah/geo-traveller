---
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getAllPosts, postSlug, tagSlug, readMinutes, formatDate } from '../../lib/posts';
import { absoluteUrl, blogPostingLd, breadcrumbLd, countWords, deriveDescription, SITE } from '../../lib/seo';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = formatDate(post.data.publishDate);
const mins = readMinutes(post);
const slug = postSlug(post);
const url = `${SITE.url}/posts/${slug}/`;
const description = post.data.excerpt || deriveDescription(post.body);
const wordCount = countWords(post.body);
const publishDate = post.data.originalDate ?? post.data.publishDate;

const ld = [
  blogPostingLd({
    title: post.data.title,
    description,
    url,
    imageUrl: post.data.cover,
    publishDate,
    modifiedDate: post.data.publishDate,
    tags: post.data.tags ?? [],
    wordCount,
    readingMinutes: mins,
  }),
  breadcrumbLd([
    { name: 'Home', url: '/' },
    { name: 'Archive', url: '/archive/' },
    { name: post.data.title, url: `/posts/${slug}/` },
  ]),
];
---

<Base
  title={post.data.title}
  description={description}
  ogImage={post.data.cover}
  publishedTime={publishDate}
  modifiedTime={post.data.publishDate}
  ogType="article"
  articleTags={post.data.tags}
  articleAuthor={SITE.author.name}
  jsonLd={ld}
>
  <article class="with-sidebar">
    <div class="main-col post-main">
      <Breadcrumbs crumbs={[
        { name: 'Home', url: '/' },
        { name: 'Archive', url: '/archive/' },
        { name: post.data.title },
      ]} />
      <header class="post-header">
        <div class="kicker">
          {date}
          {post.data.locationName && ` · ${post.data.locationName}`}
          {` · ${mins} min read`}
        </div>
        <h1>{post.data.title}</h1>
        {post.data.excerpt && <p class="lede">{post.data.excerpt}</p>}
      </header>

      {post.data.cover && (
        <div class="post-cover">
          <img src={post.data.cover} alt={`Cover image — ${post.data.title}`} width="1200" height="675" loading="eager" />
        </div>
      )}

      <div class="post-body" data-pagefind-body>
        <Content />
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <footer class="post-footer">
          <span>Filed under:</span>
          {post.data.tags.map((t) => (
            <a class="tag" href={`/tags/${tagSlug(t)}/`} rel="tag">{t}</a>
          ))}
        </footer>
      )}

      <RelatedPosts current={post} />
      <Comments />
    </div>
    <Sidebar currentSlug={slug} />
  </article>
</Base>
