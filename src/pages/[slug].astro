---
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import ContactForm from '../components/ContactForm.astro';
import { getCollection, render } from 'astro:content';
import { personLd, breadcrumbLd, SITE } from '../lib/seo';
import { getAuthorPhoto, AUTHOR_PHOTO_FALLBACK } from '../lib/author';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

// On the About page, attach Person schema so search engines + LLMs attribute authorship
// across the site to a real, identifiable human (E-E-A-T signal).
const ld: Record<string, unknown>[] = [
  breadcrumbLd([
    { name: 'Home', url: '/' },
    { name: page.data.title, url: `/${page.data.slug}/` },
  ]),
];
if (page.data.slug === 'about') ld.push(personLd());

const authorPhoto = page.data.slug === 'about' ? await getAuthorPhoto() : '';
---

<Base title={page.data.title} description={page.data.description} jsonLd={ld}>
  <article class="with-sidebar">
    <div class="main-col">
      <header class={page.data.slug === 'about' ? 'page-header about-header' : 'page-header'}>
        {page.data.slug === 'about' && (
          <div class="about-photo">
            <img
              src={authorPhoto}
              alt={SITE.author.name}
              class={authorPhoto === AUTHOR_PHOTO_FALLBACK ? 'is-fallback' : ''}
              onerror={`this.onerror=null;this.src='${AUTHOR_PHOTO_FALLBACK}';this.classList.add('is-fallback')`}
            />
          </div>
        )}
        <h1 class="page-title">{page.data.title}</h1>
        {page.data.description && (
          <p class="page-subtitle">{page.data.description}</p>
        )}
      </header>
      <div class="post-body" style="max-width: var(--measure); margin: 0 auto;">
        <Content />
      </div>
      {page.data.slug === 'contact' && <ContactForm />}
    </div>
    <Sidebar />
  </article>
</Base>

<style>
  .page-header {
    text-align: center;
    padding: 1.5rem 0 2.5rem;
    max-width: var(--measure);
    margin: 0 auto;
  }
  .page-subtitle {
    color: var(--muted);
    font-style: italic;
    margin: 0.5rem 0 0;
  }
  .about-photo {
    width: 8.5rem;
    height: 8.5rem;
    margin: 0 auto 1.25rem;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-warm);
    border: 1px solid var(--rule);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }
  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .about-photo img.is-fallback {
    object-fit: contain;
    padding: 1rem;
  }
</style>
