---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getAllPosts, postPath, readMinutes, formatDate, tagSlug, type Post } from '../lib/posts';

const posts = await getAllPosts();
const [featured, ...rest] = posts;
const featuredDate = featured ? formatDate(featured.data.publishDate) : '';
const featuredMins = featured ? readMinutes(featured) : 0;

// Build category sections. Each is a tag name that surfaces as a section.
// Order matters — top = most prominent.
const CATEGORY_ORDER: { label: string; tag: string }[] = [
  { label: 'Geo Daily', tag: 'Geo Daily' },
  { label: 'India', tag: 'India' },
  { label: 'Bhutan', tag: 'Bhutan' },
  { label: 'Himachal Pradesh', tag: 'Himachal Pradesh' },
  { label: 'Festivals', tag: 'Festival' },
  { label: 'Flight', tag: 'Flight' },
];

function bySection(tagName: string, n: number): Post[] {
  const lower = tagName.toLowerCase();
  return rest
    .filter((p) =>
      (p.data.tags ?? []).some((t) => t.toLowerCase() === lower)
    )
    .slice(0, n);
}

const sections = CATEGORY_ORDER
  .map((c) => ({ ...c, posts: bySection(c.tag, 3) }))
  .filter((s) => s.posts.length > 0);

// Posts not surfaced in any section yet — show in a "Latest" catchall at the end.
const surfacedIds = new Set(sections.flatMap((s) => s.posts.map((p) => p.id)));
const everythingElse = rest.filter((p) => !surfacedIds.has(p.id)).slice(0, 9);
---

<Base>
  <section class="hero">
    <h1>Notes from the long way around.</h1>
    <p>Stories from places I've wandered through — the obvious ones, the obscure ones, and everything between.</p>
  </section>

  <div class="with-sidebar">
    <div class="main-col">
      {featured && (
        <a class="featured" href={postPath(featured)}>
          {featured.data.cover ? (
            <div class="cover"><img src={featured.data.cover} alt={featured.data.title} /></div>
          ) : (
            <div class="cover placeholder" aria-hidden="true"></div>
          )}
          <div class="featured-text">
            <div class="kicker">
              Latest · {featuredDate}
              {featured.data.locationName && ` · ${featured.data.locationName}`}
              {` · ${featuredMins} min read`}
            </div>
            <h2>{featured.data.title}</h2>
            {featured.data.excerpt && <p class="excerpt">{featured.data.excerpt}</p>}
            <span class="read-more">Read the story →</span>
          </div>
        </a>
      )}

      {sections.map((sec) => (
        <section class="section">
          <header class="section-heading">
            <h2>{sec.label}</h2>
            <a class="see-all" href={`/tags/${tagSlug(sec.tag)}/`}>See all →</a>
          </header>
          <div class="post-grid two-up">
            {sec.posts.slice(0, 2).map((post) => <PostCard post={post} />)}
          </div>
        </section>
      ))}

      {everythingElse.length > 0 && (
        <section class="section">
          <header class="section-heading">
            <h2>More from the archive</h2>
            <a class="see-all" href="/archive/">Full archive →</a>
          </header>
          <div class="post-grid two-up">
            {everythingElse.slice(0, 6).map((post) => <PostCard post={post} />)}
          </div>
        </section>
      )}
    </div>
    <Sidebar />
  </div>
</Base>
