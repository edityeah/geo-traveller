---
import Base from '../layouts/Base.astro';
import { getAllPosts, postPath, readMinutes, formatDateShort } from '../lib/posts';

const posts = await getAllPosts();
---

<Base title="Archive">
  <h1 class="page-title">Archive</h1>
  <p class="page-subtitle">{posts.length} {posts.length === 1 ? 'post' : 'posts'}, newest first.</p>

  <ul class="archive-list">
    {posts.map((post) => (
      <li>
        <span class="date">{formatDateShort(post.data.publishDate)}</span>
        <a href={postPath(post)}>{post.data.title}</a>
        <span class="read-time">{readMinutes(post)} min</span>
      </li>
    ))}
  </ul>
</Base>
